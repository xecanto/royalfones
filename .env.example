# ─────────────────────────────────────────────────────────
# Supabase
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# Your Supabase project URL (found in Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (found in Project Settings → API)
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────
# Cloudflare R2
# ─────────────────────────────────────────────────────────

# Public URL of your R2 bucket (enable public access in R2 dashboard)
# e.g. https://pub-xxxxxxxxxxxxxxxx.r2.dev
VITE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev
